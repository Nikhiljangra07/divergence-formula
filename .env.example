# Copy to .env or export in your shell. Scripts read os.environ directly;
# the load_dotenv() calls in corpus_run/ are a local convenience only.

# DeepSeek generator calls are routed via OpenRouter (no native key program):
OPENROUTER_API_KEY=your-key-here
# Gemini 2.5 Pro — the neutral judge for all benchmark verdicts:
GEMINI_API_KEY=your-key-here
# Claude (Haiku in-loop gate; Haiku 4.5 benchmark competitor):
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional — only for the GPT-judge comparison scripts:
OPENAI_API_KEY=your-key-here
